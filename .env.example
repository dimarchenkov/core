CORE_ENV=local
CORE_DEBUG=true
CORE_LOG_LEVEL=INFO
CORE_API_HOST=0.0.0.0
CORE_API_PORT=8000
CORE_DATABASE_URL=postgresql+psycopg://core:core@postgres:5432/core
CORE_REDIS_URL=redis://redis:6379/0
CORE_JWT_SECRET=replace-with-a-long-random-jwt-secret
# AQSI remains inert until explicitly enabled and given a real secret key.
CORE_AQSI_ENABLED=false
# CORE_AQSI_API_KEY=replace-with-aqsi-api-key
CORE_AQSI_TAX_CODE=6
# Set only when the AQSI account has more than one active shop.
# CORE_AQSI_SHOP_ID=replace-with-aqsi-shop-id
CORE_AQSI_DEFAULT_GROUP_ID=core-default-goods
CORE_AQSI_DEFAULT_GROUP_NAME=Товары Core
POSTGRES_DB=core
POSTGRES_USER=core
POSTGRES_PASSWORD=core
